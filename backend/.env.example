# Local connection string (localhost:5432)
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?schema=public"

# Docker connection string (db:5432)
DATABASE_URL_DOCKER="postgresql://user:password@db:5432/dbname?schema=public"

# Individual variables used by docker-compose.yml
DATABASE_USER="user"
DATABASE_PASSWORD="password"
DATABASE_NAME="dbname"
DATABASE_HOST="localhost"
DATABASE_PORT=5432
PORT = 3000